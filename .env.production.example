# =============================================================================
# Backend Production Environment Variables
# Copy to .env.production and fill in real values before deploying.
# These are referenced by configs-v2/*.yaml via ${VAR} substitution
# and by docker-compose.v2.yml.
# =============================================================================

# === PostgreSQL ===
POSTGRES_USER=market-user
POSTGRES_PASSWORD=CHANGE_ME

# === Redis ===
REDIS_PASSWORD=CHANGE_ME

# === Alchemy (Arbitrum Sepolia) ===
ALCHEMY_API_KEY=CHANGE_ME
ALCHEMY_POLICY_ID=CHANGE_ME

# === Signer (AA bundler wallet) ===
SIGNER_ADDRESS=CHANGE_ME
SIGNER_PRIVATE_KEY=CHANGE_ME

# === S3 ===
S3_BUCKET=CHANGE_ME
S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_TENANT_SLUG=arb-sepolia-usdc

# === Privy ===
PRIVY_APP_ID=CHANGE_ME
PRIVY_APP_SECRET=CHANGE_ME

# === Block Listener ===
FACTORY_ADDRESS=CHANGE_ME
CONDITIONAL_TOKENS_ADDRESS=CHANGE_ME

# === Sentry ===
SENTRY_DSN=

# === Lark ===
LARK_WEBHOOK_KEY=

# === OpenAI (optional, for translation) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=
